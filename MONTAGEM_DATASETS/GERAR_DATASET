paths = [
     "dataset_mariana.csv",
     "dataset_pedro_f.csv"
 ]




SEQ_LEN = 500  # tamanho final por janela (amostras)

dfs = []
offset = 0

for p in paths:
    d = pd.read_csv(p)

    required_cols = {"t_s", "sinal_filtrado", "janela", "classificacao"}
    missing = required_cols - set(d.columns)
    if missing:
        raise ValueError(f"CSV {p} sem colunas obrigatórias: {missing}")

    d["janela"] = d["janela"].astype(int)
    d["janela"] = d["janela"] + offset

    # CORRETO: +1 para não repetir o último ID
    offset = int(d["janela"].max())+1

    dfs.append(d)

df = pd.concat(dfs, ignore_index=True)
df = df.sort_values(["janela", "t_s"], kind="mergesort").reset_index(drop=True)
df.to_csv("dataset_juntos.csv", index=False, encoding="utf-8", sep=",")