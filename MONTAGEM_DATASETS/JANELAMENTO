import numpy as np
import pandas as pd

#ARQUIVO RESPONSÁVEL POR CRIAR O JANELAMENTO, DE 500MS. ELE CRIA UMA COLUNA NO DF E CADA JANELA RECEBE UM NuMERO, QUE COMEÇA EM 1 E VAI SENDO INCREMENTADO A 
#CADA NOVA JANELA


ARQUIVO_ENTRADA = "data/mariana/filtrado/careta.csv"  
ARQUIVO_SAIDA   = "data/mariana/janelamento/careta.csv"
JANELA_S = 1

df = pd.read_csv(ARQUIVO_ENTRADA)

tempo_col = df.columns[0]
t = df[tempo_col].astype(float).to_numpy()

# referência: início do arquivo (primeiro tempo)
t0 = float(t[0])

#id janela
janela_idx = np.floor((t - t0) / JANELA_S).astype(int) + 1

df["janela"] = janela_idx
df.to_csv(ARQUIVO_SAIDA, index=False)

print(f"Salvo em: {ARQUIVO_SAIDA}")
print(f"Total de janelas: {df['janela'].max()}")
